extends ../layout

block content
  style.
    .container { width: 100%; max-width: 1000px; }
    .header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .btn-nuevo { background-color: #50fa7b; color: #282a36; padding: 10px 20px; text-decoration: none; border-radius: 8px; font-weight: bold; }
    .btn-nuevo:hover { background-color: #40c863; }
    .data-table { width: 100%; border-collapse: collapse; background-color: #2a2a40; border-radius: 10px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.3); }
    .data-table th, .data-table td { padding: 15px; text-align: left; border-bottom: 1px solid #44475a; }
    .data-table th { background-color: #44475a; color: #f8f8f2; text-transform: uppercase; font-size: 13px; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover { background-color: #383a59; }
    .btn-accion { background-color: #8be9fd; color: #282a36; padding: 6px 12px; text-decoration: none; border-radius: 4px; font-size: 12px; font-weight: bold; margin-right: 5px; }
    .btn-accion:hover { background-color: #6edbf0; }
    .badge-activo { background-color: #50fa7b; color: #282a36; padding: 3px 8px; border-radius: 12px; font-size: 11px; font-weight: bold; }
    .badge-inactivo { background-color: #ff5555; color: #f8f8f2; padding: 3px 8px; border-radius: 12px; font-size: 11px; font-weight: bold; }

  .container
    .header-flex
      div
        h1= titulo || 'Nómina de Empleados'
        p Gestioná el personal registrado
      div
        a.btn-nuevo(href="/api/empleados/form") Nuevo Empleado

    table.data-table
      thead
        tr
          th Nombre Completo
          th DNI
          th Empresa
          th Estado
          th Acciones
      tbody
        if empleados && empleados.length > 0
          each emp in empleados
            tr
              td= `${emp.nombre} ${emp.apellido}`
              td= emp.dni
              td= emp.empresaId
              td
                if emp.activo
                  span.badge-activo Activo
                else
                  span.badge-inactivo Inactivo
              td
                a.btn-accion(href=`/api/empleados/${emp.id}`) Ver
                a.btn-accion(href=`/api/empleados/form/${emp.id}`) Editar
        else
          tr
            td(colspan="6" style="text-align: center; padding: 30px; color: #6272a4;") No hay empleados registrados en el sistema.