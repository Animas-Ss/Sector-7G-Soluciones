doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= titulo
    style.
      body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #1e1e2f; color: #ffffff; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
      .card { background-color: #2a2a40; padding: 40px; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.3); text-align: center; }
      h1 { color: #ff79c6; margin-top: 0; }
      ul { list-style-type: none; padding: 0; display: flex; gap: 10px; justify-content: center; }
      li { background: #44475a; padding: 5px 15px; border-radius: 20px; font-size: 0.9em; }
  body
    div.card
      h1= mensaje || 'Vista Dinámica'
      p ¡Esta vista Pug fue cargada automáticamente!
      if tecnologias
        p Tecnologías en uso:
        ul
          each item in tecnologias
            li= item
