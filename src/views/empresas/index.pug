extends ../layout

block content
  style.
    .container { width: 100%; max-width: 1000px; }
    .header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .btn-nuevo { background-color: #50fa7b; color: #282a36; padding: 10px 20px; text-decoration: none; border-radius: 8px; font-weight: bold; }
    .btn-nuevo:hover { background-color: #40c863; }
    .empresas-table { width: 100%; border-collapse: collapse; background-color: #2a2a40; border-radius: 10px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.3); }
    .empresas-table th, .empresas-table td { padding: 15px; text-align: left; border-bottom: 1px solid #44475a; }
    .empresas-table th { background-color: #44475a; color: #f8f8f2; text-transform: uppercase; font-size: 13px; }
    .empresas-table tr:last-child td { border-bottom: none; }
    .empresas-table tr:hover { background-color: #383a59; }
    .btn-accion { background-color: #8be9fd; color: #282a36; padding: 6px 12px; text-decoration: none; border-radius: 4px; font-size: 12px; font-weight: bold; margin-right: 5px; }
    .btn-accion:hover { background-color: #6edbf0; }
    .badge-activo { background-color: #50fa7b; color: #282a36; padding: 3px 8px; border-radius: 12px; font-size: 11px; font-weight: bold; }
    .badge-inactivo { background-color: #ff5555; color: #f8f8f2; padding: 3px 8px; border-radius: 12px; font-size: 11px; font-weight: bold; }

  .container
    .header-flex
      div
        h1= titulo || 'Directorio de Empresas'
        p Gestioná las empresas clientes registradas en el sistema.
      div
        a.btn-nuevo(href="/api/empresas/form") + Nueva Empresa

    table.empresas-table
      thead
        tr
          th Nombre
          th CUIT
          th Rubro
          th Contacto
          th Estado
          th Acciones
      tbody
        if empresas && empresas.length > 0
          each emp in empresas
            tr
              td= emp.nombre
              td= emp.cuit
              td= emp.rubro
              td= emp.contacto
              td
                if emp.activo
                  span.badge-activo Activo
                else
                  span.badge-inactivo Inactivo
              td
                a.btn-accion(href=`/api/empresas/${emp.id}`) Ver
                a.btn-accion(href=`/api/empresas/form/${emp.id}`) Editar
        else
          tr
            td(colspan="6" style="text-align: center; padding: 30px; color: #6272a4;") No hay empresas registradas actualmente.