doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= titulo || 'Talento Evolutivo S.A.'
    style.
      /* Estilos base compartidos*/
      body { 
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
        background-color: #1e1e2f; 
        color: #ffffff; 
        margin: 0; 
      }
      header {
        background-color: #2a2a40;
        padding: 15px 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
      }
      nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        gap: 20px;
        justify-content: center;
      }
      nav a {
        color: #ff79c6;
        text-decoration: none;
        font-weight: bold;
        transition: color 0.3s;
      }
      nav a:hover {
        color: #bd93f9;
      }
      main {
        padding: 40px;
        display: flex;
        justify-content: center;
      }
  body
    header
      nav
        ul
            li: a(href="/index") Inicio
            li: a(href="/empresas") Empresas
            li: a(href="/empleados") Empleados
            li: a(href="#") Liquidaciones
            li: a(href="/socios") Socios
            li: a(href="#") Novedades
            li: a(href="#") Seguimientos
            li: a(href="/resumen") Reportes
            li: a(href="#") Auditoría
    main
      //- Contenido 
      block content