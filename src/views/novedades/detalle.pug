extends ../layout

block content
  style.
    .container { width: 100%; max-width: 800px; margin: 0 auto; }
    .card-detalle { background-color: #2a2a40; padding: 30px; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.3); margin-bottom: 30px; }
    .card-detalle h1 { color: #8be9fd; margin-top: 0; border-bottom: 2px solid #44475a; padding-bottom: 10px; }
    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 25px; }
    .info-item { background-color: #1e1e2f; padding: 15px; border-radius: 8px; border-left: 4px solid #bd93f9; }
    .info-item.full-width { grid-column: span 2; border-left-color: #ff79c6; }
    .info-label { color: #6272a4; font-size: 0.85em; font-weight: bold; text-transform: uppercase; margin-bottom: 5px; }
    .info-valor { color: #f8f8f2; font-size: 1.1em; }
    .btn-volver { display: inline-block; margin-bottom: 20px; color: #ff79c6; text-decoration: none; font-weight: bold; }
    .btn-volver:hover { text-decoration: underline; color: #ff92d0; }
    
    .badge-pendiente { color: #f1fa8c; font-weight: bold; }
    .badge-procesada { color: #50fa7b; font-weight: bold; }
    .badge-rechazada { color: #ff5555; font-weight: bold; }
    .badge-inactivo { color: #ff5555; font-weight: bold; }
    
    .seccion-seguimientos { background-color: #2a2a40; padding: 30px; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
    .seccion-seguimientos h2 { color: #ff79c6; margin-top: 0; border-bottom: 2px solid #44475a; padding-bottom: 10px; display: flex; justify-content: space-between; align-items: center; }
    .btn-comentario { background-color: #50fa7b; color: #282a36; padding: 6px 12px; text-decoration: none; border-radius: 6px; font-size: 14px; font-weight: bold; }
    .btn-comentario:hover { background-color: #40c863; }
    
    .timeline { list-style: none; padding: 0; margin: 20px 0 0 0; }
    .timeline-item { background-color: #1e1e2f; padding: 15px; border-radius: 8px; margin-bottom: 15px; border-left: 4px solid #50fa7b; }
    .timeline-header { display: flex; justify-content: space-between; color: #6272a4; font-size: 0.85em; margin-bottom: 8px; }
    .timeline-responsable { font-weight: bold; color: #8be9fd; }
    .timeline-comentario { color: #f8f8f2; }

  .container
    a.btn-volver(href="/novedades") ← Volver a Novedades

    .card-detalle
      h1= `${novedad.tipo} - #${(novedad._id || novedad.id).toString().substring(0,8)}...`
      
      .info-grid
        .info-item
          .info-label Empleado
          .info-valor= novedad.empleado ? `${novedad.empleado.nombre} ${novedad.empleado.apellido}` : 'N/A'
        
        .info-item
          .info-label Empresa
          .info-valor= novedad.empresa ? novedad.empresa.nombre : 'N/A'
          
        .info-item
          .info-label Fecha de Registro
          .info-valor= novedad.fecha
          
        .info-item
          .info-label Estado
          .info-valor
            if !novedad.activo
              span.badge-inactivo Inactiva (Eliminada)
            else if novedad.estado === 'pendiente'
              span.badge-pendiente Pendiente
            else if novedad.estado === 'procesada'
              span.badge-procesada Procesada
            else if novedad.estado === 'rechazada'
              span.badge-rechazada Rechazada
            else
              span.badge-pendiente= novedad.estado || 'Pendiente'
              
        .info-item.full-width
          .info-label Descripción
          .info-valor(style="white-space: pre-wrap;")= novedad.descripcion

    .seccion-seguimientos
      h2
        span Historial de Seguimientos
        a.btn-comentario(href=`/seguimientos/form?novedadId=${novedad._id || novedad.id}`) + Agregar Comentario
      
      if novedad.seguimientos && novedad.seguimientos.length > 0
        ul.timeline
          each seg in novedad.seguimientos
            li.timeline-item(style=!seg.activo ? "border-left-color: #ff5555; opacity: 0.6;" : "")
              .timeline-header
                span.timeline-responsable= seg.responsable
                span= seg.fecha
              .timeline-comentario= seg.comentario
      else
        p(style="color: #6272a4; text-align: center; margin-top: 20px;") No se registraron comentarios de seguimiento en esta novedad.
