extends ../layout

block content
  .container
    h1 Dashboard Operativo - Talento Evolutivo S.A.
    
    .stats-grid(style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 30px;")
      .stat-card(style="background: #44475a; padding: 20px; border-radius: 12px; text-align: center;")
        h3 Total Empresas
        p(style="font-size: 32px; color: #50fa7b; font-weight: bold;")= resumen.totalEmpresas
      
      .stat-card(style="background: #44475a; padding: 20px; border-radius: 12px; text-align: center;")
        h3 Total Empleados
        p(style="font-size: 32px; color: #8be9fd; font-weight: bold;")= resumen.totalEmpleados
      
      .stat-card(style="background: #44475a; padding: 20px; border-radius: 12px; text-align: center;")
        h3 Novedades Pendientes
        p(style="font-size: 32px; color: #ffb86c; font-weight: bold;")= resumen.novedadesPendientes

    .chart-placeholder(style="margin-top: 40px; background: #2a2a40; padding: 40px; border-radius: 12px; text-align: center; border: 2px dashed #44475a;")
      h2 Distribución de Novedades por Tipo
      p [Aquí se integraría Chart.js en la segunda etapa]
      ul(style="list-style: none; padding: 0; margin-top: 20px; text-align: left; max-width: 400px; margin-left: auto; margin-right: auto;")
        each val, key in resumen.novedadesPorTipo
          li(style="margin-bottom: 10px; display: flex; justify-content: space-between;")
            span= key
            span.badge-activo= val
