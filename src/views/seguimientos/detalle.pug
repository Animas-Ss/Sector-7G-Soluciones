extends ../layout

block content
  style.
    .container { width: 100%; max-width: 800px; margin: 0 auto; }
    .card-detalle { background-color: #2a2a40; padding: 30px; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
    .card-detalle h1 { color: #8be9fd; margin-top: 0; border-bottom: 2px solid #44475a; padding-bottom: 10px; }
    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 25px; }
    .info-item { background-color: #1e1e2f; padding: 15px; border-radius: 8px; border-left: 4px solid #bd93f9; }
    .info-item.full-width { grid-column: span 2; border-left-color: #50fa7b; }
    .info-label { color: #6272a4; font-size: 0.85em; font-weight: bold; text-transform: uppercase; margin-bottom: 5px; }
    .info-valor { color: #f8f8f2; font-size: 1.1em; }
    .btn-volver { display: inline-block; margin-bottom: 20px; color: #ff79c6; text-decoration: none; font-weight: bold; }
    .btn-volver:hover { text-decoration: underline; color: #ff92d0; }
    
    .badge-activo { color: #50fa7b; font-weight: bold; }
    .badge-inactivo { color: #ff5555; font-weight: bold; }

  .container
    a.btn-volver(href="/seguimientos") ← Volver a Seguimientos

    .card-detalle
      h1= `Seguimiento - #${(seguimiento._id || seguimiento.id).toString().substring(0,8)}...`
      
      .info-grid
        .info-item
          .info-label Responsable / Estado
          .info-valor= seguimiento.responsable || seguimiento.estado
        
        .info-item
          .info-label Fecha de Comentario
          .info-valor= seguimiento.fecha
          
        .info-item
          .info-label Novedad Relacionada
          .info-valor
            if seguimiento.novedad
              a(href=`/novedades/${seguimiento.novedad.id}` style="color: #ff79c6; text-decoration: none; font-weight: bold;")= seguimiento.novedad.tipo
              span.text-muted= ` (${seguimiento.novedad.estado})`
            else
              span N/A
              
        .info-item
          .info-label Empleado / Empresa
          .info-valor
            if seguimiento.empleado
              span= `${seguimiento.empleado.nombre} ${seguimiento.empleado.apellido}`
            else
              span N/A
            if seguimiento.empresa
              span.text-muted= ` @ ${seguimiento.empresa.nombre}`
              
        .info-item
          .info-label Estado
          .info-valor
            if seguimiento.activo
              span.badge-activo Activo
            else
              span.badge-inactivo Inactivo (Eliminado)
              
        .info-item.full-width
          .info-label Comentario / Observación
          .info-valor(style="white-space: pre-wrap;")= seguimiento.comentario || seguimiento.observacion
