extends ../layout

block content
  style.
    .container { width: 100%; max-width: 1000px; }
    .header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .btn-nuevo { background-color: #50fa7b; color: #282a36; padding: 10px 20px; text-decoration: none; border-radius: 8px; font-weight: bold; }
    .btn-nuevo:hover { background-color: #40c863; }
    
    .data-table { width: 100%; border-collapse: collapse; background-color: #2a2a40; border-radius: 10px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.3); }
    .data-table th, .data-table td { padding: 15px; text-align: left; border-bottom: 1px solid #44475a; }
    .data-table th { background-color: #44475a; color: #f8f8f2; text-transform: uppercase; font-size: 13px; }
    .data-table tr:hover { background-color: #383a59; }
    
    .btn-accion { background-color: #8be9fd; color: #282a36; padding: 6px 12px; text-decoration: none; border-radius: 4px; font-size: 12px; font-weight: bold; margin-right: 5px; display: inline-flex; align-items: center; justify-content: center; border: none; cursor: pointer; }
    .btn-accion:hover { background-color: #6edbf0; }
    .btn-baja { background-color: #ff5555; color: #f8f8f2; }
    .btn-baja:hover { background-color: #ff2222; }
    
    .text-muted { color: #6272a4; font-size: 0.9em; }

  .container
    .header-flex
      div
        h1= titulo
        p Historial de acciones y comentarios sobre las novedades.
      a.btn-nuevo(href="/seguimientos/form") + Agregar Comentario

    table.data-table
      thead
        tr
          th ID
          th Novedad Relacionada
          th Empleado / Empresa
          th Fecha
          th Responsable / Estado
          th Comentario / Observación
          th Acciones
      tbody
        if seguimientos && seguimientos.length > 0
          each seg in seguimientos
            tr
              td(style="font-family: monospace; font-size: 11px; max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;")= seg._id || seg.id
              td
                if seg.novedad
                  a(href=`/novedades/${seg.novedad.id}` style="color: #ff79c6; text-decoration: none; font-weight: bold;")= seg.novedad.tipo
                  br
                  span.text-muted= `Estado: ${seg.novedad.estado}`
                else
                  span N/A
              td
                if seg.empleado
                  span= `${seg.empleado.nombre} ${seg.empleado.apellido}`
                else
                  span N/A
                if seg.empresa
                  br
                  span.text-muted= seg.empresa.nombre
              td= seg.fecha
              td= seg.responsable || seg.estado
              td= seg.comentario || seg.observacion
              td
                a.btn-accion(href=`/seguimientos/${seg._id || seg.id}`) Ver
                if seg.activo
                  button.btn-accion.btn-baja.js-baja(type="button" data-id=seg._id || seg.id) Eliminar
        else
          tr
            td(colspan="7" style="text-align: center; padding: 30px; color: #6272a4;") No se encontraron seguimientos registrados.

  script.
    async function darDeBaja(id) {
      if (!confirm('¿Dar de baja a este seguimiento?')) return;
      
      try {
        const response = await fetch(`/api/seguimientos/${id}`, { method: 'DELETE' });
        
        if (response.ok) {
          window.location.reload(); 
        } else {
          const errorData = await response.json().catch(() => ({}));
          alert('No se pudo realizar la acción: ' + (errorData.message || `HTTP ${response.status}`));
        }
      } catch (error) {
        console.error(error);
        alert('Error de conexión con el servidor.');
      }
    }

    document.addEventListener('click', (event) => {
      const btn = event.target.closest('button.js-baja');
      if (!btn) return;
      const id = btn.getAttribute('data-id');
      darDeBaja(id);
    });
